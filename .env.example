# NCBI/PubMed API
NCBI_API_KEY=your_ncbi_api_key_here
NCBI_EMAIL=your_email@example.com

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Unpaywall API (uses email as key)
UNPAYWALL_EMAIL=your_email@example.com

# Semantic Scholar API (optional, increases rate limit)
SEMANTIC_SCHOLAR_API_KEY=

# Database
DATABASE_PATH=database/sbma_research.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/sbma_agent.log
